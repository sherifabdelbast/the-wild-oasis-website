# Supabase – app data (cabins, bookings, guests, settings)
# From Supabase: Project Settings → API → Project URL and anon public key
SUPABASE_URL=
SUPABASE_KEY=

# Better Auth – server URL and (for DB) Postgres connection
# From Supabase: Project Settings → Database → Connection string (URI)
BETTER_AUTH_URL=
DATABASE_URL=

# Google OAuth (Better Auth social sign-in)
# From Google Cloud Console: OAuth 2.0 Client ID and Secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth (Better Auth social sign-in)
# From Meta Developers Console: App ID and App Secret
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
